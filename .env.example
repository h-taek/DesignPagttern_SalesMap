# SalesMap Java 공통 환경변수 (spring-dotenv가 루트 .env를 자동 로드)
# DB
DATABASE_URL=jdbc:postgresql://localhost:5432/salesmap
DB_USERNAME=salesmap
DB_PASSWORD=salesmap
# CORS / 내부 토큰
CORS_ORIGINS=http://localhost:5173
INTERNAL_TOKEN=dev-internal-token
# 서울 열린데이터 광장 인증키 (OA-15572) — 실제 키로 교체
OPEN_API_KEY=
OPEN_API_BASE=http://openapi.seoul.go.kr:8088
# AI 예측기
PREDICTOR=lr
